<Window x:Class="MathAnimator.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Math Animator – Hilfe &amp; Technische Informationen"
        Width="900"
        Height="650"
        Background="#121212"
        WindowStartupLocation="CenterOwner">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" MaxWidth="820">

            <TextBlock Text="Math Animator"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="White"
                       Margin="0 0 0 16"/>

            <TextBlock Text="Interaktive Visualisierung &amp; Animation mathematischer Funktionen"
                       FontSize="16"
                       Foreground="#BBBBBB"
                       Margin="0 0 0 32"/>

            <Border Background="#1E1E1E"
                    Padding="20"
                    CornerRadius="12"
                    Margin="0 0 0 20">
                <StackPanel>
                    <TextBlock Text="Über das Programm"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Margin="0 0 0 10"/>

                    <TextBlock TextWrapping="Wrap"
                               FontSize="15"
                               Foreground="#DDDDDD">
                        Math Animator ist ein interaktives Tool zur Visualisierung
                        und Animation mathematischer Funktionen in Echtzeit.

                        Ziel ist es, mathematische Zusammenhänge anschaulich darzustellen
                        und mit Parametern experimentieren zu können.
                    </TextBlock>
                </StackPanel>
            </Border>

            <Border Background="#1E1E1E"
                    Padding="20"
                    CornerRadius="12"
                    Margin="0 0 0 20">
                <StackPanel>
                    <TextBlock Text="Darstellungsarten"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Margin="0 0 0 10"/>

                    <TextBlock FontSize="15" Foreground="#DDDDDD">
                        • Funktionsmodus (y = f(x)):
                          sin(x), x² + a·x, cos(x·b)

                        • Parametermodus:
                          x(t), y(t)
                          x(t) = cos(t)
                          y(t) = sin(t)
                    </TextBlock>
                </StackPanel>
            </Border>

            <Border Background="#1E1E1E"
                    Padding="20"
                    CornerRadius="12"
                    Margin="0 0 0 20">
                <StackPanel>
                    <TextBlock Text="Parameter a, b, c"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Margin="0 0 0 10"/>

                    <TextBlock FontSize="15"
                               Foreground="#DDDDDD"
                               TextWrapping="Wrap">
                        Die Parameter a, b und c ändern sich automatisch mit der Zeit
                        und steuern die Animation der Funktion.
                    </TextBlock>
                </StackPanel>
            </Border>

            <Border Background="#1E1E1E"
                Padding="20"
                CornerRadius="12"
                Margin="0 0 0 20">

                <StackPanel>

                    <TextBlock Text="Unterstützte mathematische Funktionen"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="White"
                       Margin="0 0 0 14"/>

                    <TextBlock Text="Konstanten:"
                       FontWeight="SemiBold"
                       Foreground="White"
                       FontSize="18"/>
                    
                    <TextBlock Text="• pi, π  • tau  • e"
                       Foreground="#DDDDDD"
                       FontSize="16"/>

                    <TextBlock Margin="0 8 0 0"
                       Text="Variablen:"
                       FontWeight="SemiBold"
                       Foreground="White"
                       FontSize="18"/>
                    
                    <TextBlock Text="• x, t  • a, b, c"
                       Foreground="#DDDDDD"
                       FontSize="16"/>

                    <TextBlock Margin="0 8 0 0"
                       Text="Grundrechenarten:"
                       FontWeight="SemiBold"
                       Foreground="White"
                       FontSize="18"/>
                    
                    <TextBlock Text="• +  • -  • *  • /  • ^   (inkl. Klammern)"
                       Foreground="#DDDDDD"
                       FontSize="16"/>

                    <TextBlock Margin="0 8 0 0"
                       Text="Trigonometrie:"
                       FontWeight="SemiBold"
                       Foreground="White"
                       FontSize="18"/>
                    
                    <TextBlock Text="• sin, cos, tan"
                       Foreground="#DDDDDD"
                       FontSize="16"/>
                    
                    <TextBlock Text="• asin, acos, atan, atan2"
                       Foreground="#DDDDDD"
                       FontSize="16"/>

                    <TextBlock Margin="0 8 0 0"
                       Text="Hyperbelfunktionen:"
                       FontWeight="SemiBold"
                       Foreground="White"
                       FontSize="18"/>
                    
                    <TextBlock Text="• sinh, cosh, tanh"
                       Foreground="#DDDDDD"
                       FontSize="16"/>

                    <TextBlock Margin="0 8 0 0"
                       Text="Logarithmen &amp; Exponentialfunktionen:"
                       FontWeight="SemiBold"
                       Foreground="White"
                       FontSize="18"/>
                    
                    <TextBlock Text="• ln  • log10  • log(base, value)  • exp"
                       Foreground="#DDDDDD"
                       FontSize="16"/>

                    <TextBlock Margin="0 8 0 0"
                       Text="Weitere Funktionen:"
                       FontWeight="SemiBold"
                       Foreground="White"
                       FontSize="18"/>
                    
                    <TextBlock Text="• sqrt, cbrt"
                       Foreground="#DDDDDD"
                       FontSize="16"/>
                    
                    <TextBlock Text="• abs, round, floor, ceil"
                       Foreground="#DDDDDD"
                       FontSize="16"/>
                    
                    <TextBlock Text="• min(x, y), max(x, y), mod(x, y)"
                       Foreground="#DDDDDD"
                       FontSize="16"/>
                    
                    <TextBlock Text="• random(min, max)"
                       Foreground="#DDDDDD"
                       FontSize="16"/>
                </StackPanel>
            </Border>

            <Border Background="#1E1E1E"
                Padding="20"
                CornerRadius="12"
                Margin="0 0 0 20">

                <StackPanel>

                    <TextBlock Text="Technische Informationen"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="White"
                       Margin="0 0 0 14"/>

                    <TextBlock Text="Programmiersprache:"
                       FontWeight="SemiBold"
                       Foreground="White"
                       FontSize="18"/>
                    
                    <TextBlock Text="C#"
                       Foreground="#DDDDDD"
                       FontSize="16"/>

                    <TextBlock Margin="0 6 0 0"
                       Text="UI-Framework:"
                       FontWeight="SemiBold"
                       Foreground="White"
                       FontSize="18"/>
                    
                    <TextBlock Text="WPF (Windows Presentation Foundation)"
                       Foreground="#DDDDDD"
                       FontSize="16"/>

                    <TextBlock Margin="0 6 0 0"
                       Text="Framework / Runtime:"
                       FontWeight="SemiBold"
                       Foreground="White"
                       FontSize="18"/>
                    
                    <TextBlock Text=".NET (Windows Desktop)"
                       Foreground="#DDDDDD"
                       FontSize="16"/>

                    <TextBlock Margin="0 6 0 0"
                       Text="Entwicklungsumgebung:"
                       FontWeight="SemiBold"
                       Foreground="White"
                       FontSize="18"/>
                    
                    <TextBlock Text="Microsoft Visual Studio Community"
                       Foreground="#DDDDDD"
                       FontSize="16"/>
                    
                    <TextBlock Margin="0 6 0 0"
                       Text="Rendering:"
                       FontWeight="SemiBold"
                       Foreground="White"
                       FontSize="18"/>
                    
                    <TextBlock Text="WriteableBitmap (Software-Rendering)"
                       Foreground="#DDDDDD"
                       FontSize="16"/>

                    <TextBlock Margin="0 6 0 0"
                       Text="Mathematischer Parser:"
                       FontWeight="SemiBold"
                       Foreground="White"
                       FontSize="18"/>
                    
                    <TextBlock Text="Eigener Expression-Parser (System.Linq.Expressions)"
                       Foreground="#DDDDDD"
                       FontSize="16"/>

                    <TextBlock Margin="0 6 0 0"
                       Text="Animation:"
                       FontWeight="SemiBold"
                       Foreground="White"
                       FontSize="18"/>
                    
                    <TextBlock Text="Zeitbasierte Änderung der Parameter a, b, c"
                       Foreground="#DDDDDD"
                       FontSize="16"/>

                    <TextBlock Margin="0 6 0 0"
                       Text="Datenhaltung:"
                       FontWeight="SemiBold"
                       Foreground="White"
                       FontSize="18"/>
                    
                    <TextBlock Text="JSON (Funktionsbibliothek mit Ordnerstruktur)"
                       Foreground="#DDDDDD"
                       FontSize="16"/>

                    <TextBlock Margin="0 6 0 0"
                       Text="Plattform:"
                       FontWeight="SemiBold"
                       Foreground="White"
                       FontSize="18"/>
                    
                    <TextBlock Text="Windows Desktop (Windows 10 / 11)"
                       Foreground="#DDDDDD"
                       FontSize="16"/>
                </StackPanel>
            </Border>
            
            <Border Background="#1E1E1E"
                    Padding="20"
                    CornerRadius="12">
                <StackPanel>
                    <TextBlock Text="Rechtliches"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Margin="0 0 0 10"/>

                    <TextBlock FontSize="14"
                               Foreground="#BBBBBB"
                               TextWrapping="Wrap">
                        Dieses Programm ist urheberrechtlich geschützt.
                        Copyright © Raffael / Tschakala
                    </TextBlock>

                    <TextBlock Margin="0 8 0 0">
                        <Hyperlink NavigateUri="https://github.com/Tschakala"
                                   RequestNavigate="OnOpenLink">
                            https://github.com/Tschakala
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Window>