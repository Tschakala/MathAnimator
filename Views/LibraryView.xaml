<UserControl
    x:Class="MathAnimator.LibraryView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Margin="20">

        <TextBlock Text="Funktionsbibliothek"
                   FontSize="24"
                   Foreground="{DynamicResource ThemeForeground}"
                   Margin="0 0 0 10"/>

        <ListBox x:Name="FunctionList"
                 Height="300"
                 Background="{DynamicResource ThemeBackground}"
                 Foreground="{DynamicResource ThemeForeground}"
                 MouseDoubleClick="OnDeleteFunction"/>

        <ListBox x:Name="FolderList"
            SelectionChanged="OnFolderChanged"/>

        <Button Content="Ordner erstellen"
            Click="OnAddFolder"/>

        <Button Content="Ordner umbenennen"
            Click="OnRenameFolder"/>

        <TextBlock Text="Funktion verschieben nach:"/>

        <ComboBox x:Name="MoveTargetFolder"
            Height="32"/>

        <Button Content="Funktion verschieben"
            Click="OnMoveFunction"/>

        <Button Content="Ordner löschen"
            Click="OnDeleteFolder"/>

        <Button Content="Funktion löschen"
            Height="44"
            Click="OnDeleteFunction"/>

        <Button Content="Animieren"
                Height="44"
                Click="OnAnimate"/>

        <Button Content="Zurück"
                Height="44"
                Click="OnBack"/>
    </StackPanel>
</UserControl>