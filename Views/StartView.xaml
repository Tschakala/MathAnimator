<UserControl
    x:Class="MathAnimator.StartView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel
        VerticalAlignment="Center"
        HorizontalAlignment="Center"
        Width="300">

        <TextBlock
            Text="Math Animator"
            Foreground="White"
            FontSize="32"
            HorizontalAlignment="Center"
            Margin="0 0 0 20"/>

        <Button Content="Funktionsbibliothek"
                Click="OnLibrary"/>

        <Button Content="Eigene Funktion eingeben"
                Click="OnInput"/>

        <Button Content="Beenden"
                Click="OnExit"/>
    </StackPanel>
</UserControl>