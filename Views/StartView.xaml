<UserControl
    x:Class="MathAnimator.StartView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel
        VerticalAlignment="Center"
        HorizontalAlignment="Center"
        Width="320">

        <TextBlock
            Text="Math Animator"
            Foreground="White"
            FontSize="32"
            FontWeight="Bold"
            HorizontalAlignment="Center"
            Margin="0 0 0 24"/>

        <Button Content="Funktionsbibliothek"
                Height="48"
                Click="OnLibrary"/>

        <Button Content="Eigene Funktion eingeben"
                Height="48"
                Click="OnInput"/>

        <Button Content="Beenden"
                Height="48"
                Background="#D9534F"
                Click="OnExit"/>
    </StackPanel>
</UserControl>