<UserControl
    x:Class="MathAnimator.InputView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Margin="20">

        <TextBlock Text="Darstellungsart"
           FontSize="18"
           FontWeight="Bold"
           Margin="0 10 0 6"/>

        <StackPanel Orientation="Vertical" Margin="0 0 0 10">

            <RadioButton x:Name="FunctionMode"
                 Content="Funktionsgraph  y = f(x)"
                 IsChecked="True"
                 Checked="OnModeChanged"
                 FontSize="16"
                 Padding="8"/>

            <RadioButton x:Name="ParametricMode"
                 Content="Parameterdarstellung  x(t), y(t)"
                 Checked="OnModeChanged"
                 FontSize="16"
                 Padding="8"/>

        </StackPanel>

        <Separator/>


        <TextBlock Text="y = f(x)"/>
        <TextBox x:Name="FormulaBox"
         Text="sin(x)"
         TextChanged="OnInputChanged"/>


        <TextBlock Text="Eigene Funktion"
                   FontSize="24"
                   Foreground="White"
                   Margin="0 0 0 12"/>

        <TextBlock Text="x(t)"/>
        <TextBox x:Name="XFormulaBox" Text="cos(t)"/>

        <TextBlock Text="y(t)"/>
        <TextBox x:Name="YFormulaBox" Text="sin(t)"/>

        <TextBlock Text="a"/>
        <TextBox x:Name="ABox"
                 Text="1"
                 TextChanged="OnInputChanged"/>

        <TextBlock Text="b"/>
        <TextBox x:Name="BBox"
                 Text="0"
                 TextChanged="OnInputChanged"/>

        <TextBlock Text="c"/>
        <TextBox x:Name="CBox"
                 Text="0"
                 TextChanged="OnInputChanged"/>


        <Button Content="Animieren"
        Height="44"
        Click="OnAnimate"/>

        <Button Content="Zur Bibliothek"
        Height="44"
        Background="#28A745"
        Click="OnAddToLibrary"/>

        <Button Content="Zurück"
        Height="44"
        Background="#6C757D"
        Click="OnBack"/>


        <TextBlock x:Name="ErrorText"
                   Foreground="Red"
                   Margin="0 10 0 0"/>

        <Image x:Name="Preview"
               Width="600"
               Height="300"
               Margin="0 10 0 0"/>


    </StackPanel>
</UserControl>