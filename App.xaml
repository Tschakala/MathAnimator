<Application x:Class="MathAnimator.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">

	<Application.Resources>

		<SolidColorBrush x:Key="ThemeBackground" Color="Black"/>
		<SolidColorBrush x:Key="ThemeForeground" Color="White"/>
		<SolidColorBrush x:Key="ThemeAccent" Color="#3A7AFE"/>
		<SolidColorBrush x:Key="ThemeAccentHover" Color="#2F65D9"/>
		<SolidColorBrush x:Key="ThemeAccentPressed" Color="#244EB0"/>
		<SolidColorBrush x:Key="ThemeDisabled" Color="#AAAAAA"/>
		
		<Style TargetType="Button">
			<Setter Property="MinHeight" Value="48"/>
			<Setter Property="Padding" Value="18,10"/>

			<Setter Property="FontSize" Value="16"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
			<Setter Property="Margin" Value="0,8,0,0"/>

			<Setter Property="Background" Value="{DynamicResource ThemeAccent}"/>
			<Setter Property="Foreground" Value="{DynamicResource ThemeForeground}"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Cursor" Value="Hand"/>

			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border x:Name="Border"
								Background="{TemplateBinding Background}"
								CornerRadius="8">
							<ContentPresenter
								HorizontalAlignment="Center"
								VerticalAlignment="Center"/>
						</Border>

						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="Border"
										Property="Background"
										Value="{DynamicResource ThemeAccentHover}"/>
							</Trigger>
							<Trigger Property="IsPressed" Value="True">
								<Setter TargetName="Border"
										Property="Background"
										Value="{DynamicResource ThemeAccentPressed}"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<Style TargetType="TextBox">
			<Setter Property="FontSize" Value="16"/>
			<Setter Property="Padding" Value="10,6"/>
			<Setter Property="MinHeight" Value="36"/>
			<Setter Property="Margin" Value="0,6,0,6"/>

			<Setter Property="AcceptsReturn" Value="False"/>
			<Setter Property="TextWrapping" Value="NoWrap"/>
			<Setter Property="VerticalScrollBarVisibility" Value="Disabled"/>
			<Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>

			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="BorderBrush" Value="#555"/>

			<Setter Property="Background" Value="{DynamicResource ThemeBackground}"/>
			<Setter Property="Foreground" Value="{DynamicResource ThemeForeground}"/>
		</Style>
		
		<Style TargetType="ListBox">
			<Setter Property="FontSize" Value="14"/>
			<Setter Property="Padding" Value="6"/>

			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="BorderBrush" Value="#555"/>

			<Setter Property="Background" Value="{DynamicResource ThemeBackground}"/>
			<Setter Property="Foreground" Value="{DynamicResource ThemeForeground}"/>
		</Style>
	</Application.Resources>
</Application>